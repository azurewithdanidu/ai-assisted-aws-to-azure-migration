%%{ init: { "theme": "default", "flowchart": { "curve": "basis" } } }%%
graph TB
    classDef userLayer fill:#e8f5e9,stroke:#388e3c,color:#1b5e20
    classDef frontendLayer fill:#e3f2fd,stroke:#1565c0,color:#0d47a1
    classDef computeLayer fill:#fce4ec,stroke:#880e4f,color:#880e4f
    classDef storageLayer fill:#f3e5f5,stroke:#4a148c,color:#4a148c
    classDef identityLayer fill:#e8eaf6,stroke:#283593,color:#283593
    classDef monitorLayer fill:#e0f7fa,stroke:#006064,color:#006064
    classDef infraLayer fill:#fafafa,stroke:#9e9e9e,color:#424242
    classDef cicdLayer fill:#fff8e1,stroke:#f57f17,color:#e65100
    classDef securityLayer fill:#fbe9e7,stroke:#bf360c,color:#bf360c

    subgraph USERS["👤 Users / Browsers"]
        USER[Browser Client<br/>Photo Gallery SPA<br/>index.html]:::userLayer
    end

    subgraph FRONTEND["🌐 Static Hosting — Azure Static Web Apps (Free Tier, Australia East)"]
        SWA["Azure Static Web Apps<br/>photo-gallery-swa<br/>Free tier | Australia East<br/>Global CDN included<br/>index.html — renamed from app.html<br/>URL: *.azurestaticapps.net<br/>CI/CD: GitHub Actions"]:::frontendLayer
    end

    subgraph COMPUTE["⚡ Azure Functions — Consumption Plan Y1 (Python 3.11, Australia East)"]
        FA["Function App: photo-gallery-func<br/>Consumption Y1 | Linux | Python 3.11<br/>System-assigned Managed Identity<br/>CORS: SWA origin (restricted in prod)<br/>httpsOnly: true<br/>FUNCTIONS_EXTENSION_VERSION: ~4"]:::computeLayer

        UPLOAD["upload_image()<br/>POST /api/upload<br/>Generates SAS write URL + blob name<br/>Stores metadata in blob.metadata<br/>Returns: { sas_url, blob_name }"]:::computeLayer

        LIST["list_images()<br/>GET /api/files?prefix=&maxResults=50<br/>Lists blobs with metadata<br/>Generates SAS read URLs<br/>Returns: [ { blob_name, url, metadata } ]"]:::computeLayer

        VIEW["get_view_url()<br/>GET /api/files/{fileId}/view-url<br/>Lookup by fileId/ prefix<br/>Returns: { view_url } with 1-hour expiry"]:::computeLayer

        DELETE["delete_image()<br/>DELETE /api/files/{fileId}<br/>Lists blobs under fileId/ prefix<br/>Per-blob delete loop<br/>Returns: { deletedKeys }"]:::computeLayer
    end

    subgraph STORAGE["🗄️ Azure Blob Storage — Standard LRS, Hot Tier (Australia East)"]
        SA["Storage Account: photogallerysto<br/>Standard LRS (dev/staging)<br/>Standard GRS (prod)<br/>StorageV2 | Hot tier<br/>allowBlobPublicAccess: false<br/>minimumTlsVersion: TLS1_2<br/>supportsHttpsTrafficOnly: true"]:::storageLayer

        IMGCONTAINER["Container: images<br/>Private access (no public blobs)<br/>Blob versioning: enabled (prod)<br/>CORS: configured for SWA origin<br/>Key pattern: {uuid4}/{filename}<br/>Max object size: 10 MB (SAS policy)"]:::storageLayer

        FUNCSTORAGE["Container: azure-webjobs-*<br/>Function App runtime storage<br/>Function keys, host ID, triggers<br/>(internal use — same storage account)"]:::storageLayer
    end

    subgraph IDENTITY["🔐 Identity & Access Control — Azure RBAC"]
        MI["System-assigned Managed Identity<br/>on photo-gallery-func<br/>Replaces: image-upload-LambdaExecutionRole<br/>Auth: DefaultAzureCredential()"]:::identityLayer

        RBAC["Role Assignment<br/>Storage Blob Data Contributor<br/>ID: ba92f5b4-2d11-453d-a403-e96b0029c9fe<br/>Scope: photogallerysto<br/>Principal: Function App MI"]:::identityLayer

        FUNCKEY["Function App Default Key<br/>x-functions-key header (SPA)<br/>Replaces: AWS_IAM SigV4 + static key<br/>Eliminates: AKIAXZEFIIOD2OIWPRPK risk<br/>(Key Vault-backed in prod)"]:::securityLayer
    end

    subgraph MONITOR["📊 Monitoring — Azure Monitor (Australia East)"]
        AI["Application Insights<br/>photo-gallery-appinsights<br/>Request tracing<br/>Exception tracking<br/>Live Metrics<br/>Replaces: CloudWatch Logs + X-Ray"]:::monitorLayer

        LAW["Log Analytics Workspace<br/>photo-gallery-law<br/>Retention: 30d (dev) / 90d (prod)<br/>KQL queries<br/>Replaces: CloudWatch Logs Insights"]:::monitorLayer
    end

    subgraph INFRA["🏗️ Infrastructure as Code — Azure Bicep"]
        BICEP["main.bicep<br/>6 modules:<br/>storage.bicep<br/>identity.bicep<br/>functionApp.bicep<br/>monitoring.bicep<br/>rbac.bicep<br/>staticWebApp.bicep<br/>Parameter files:<br/>dev.bicepparam<br/>staging.bicepparam<br/>prod.bicepparam"]:::infraLayer
    end

    subgraph CICD["🔄 CI/CD — GitHub Actions (OIDC / Workload Identity Federation)"]
        GHA_INFRA["deploy-infra.yml<br/>Trigger: push to main/staging/dev<br/>Bicep what-if + deploy<br/>Rollback: --rollback-on-error"]:::cicdLayer

        GHA_FUNC["deploy-functions.yml<br/>Trigger: push to main/staging/dev<br/>pip install → zip → az functionapp deploy<br/>Artifact: function-app.zip (7d)"]:::cicdLayer

        GHA_SWA["deploy-static-web.yml<br/>Trigger: push to main/staging/dev<br/>Rename app.html→index.html<br/>Patch SPA config (remove AWS key!)<br/>azure/static-web-apps-deploy@v1"]:::cicdLayer

        OIDC["OIDC Credentials<br/>AZURE_CLIENT_ID (repo secret)<br/>AZURE_TENANT_ID (repo secret)<br/>AZURE_SUBSCRIPTION_ID (repo secret)<br/>STATIC_WEB_APP_TOKEN_* (env secrets)<br/>No long-lived passwords"]:::cicdLayer
    end

    %% ─── User flows ───
    USER -->|"1. Load SPA (HTTPS)"| SWA
    SWA -->|"index.html + JS (CDN)"| USER
    USER -->|"2. API calls (x-functions-key header)"| FA

    %% ─── Function App internal routing ───
    FA --> UPLOAD
    FA --> LIST
    FA --> VIEW
    FA --> DELETE

    %% ─── Functions → Blob Storage (Managed Identity) ───
    UPLOAD -->|"generate_blob_sas(write=True, expiry=1h)"| IMGCONTAINER
    LIST -->|"list_blobs() + generate_blob_sas(read=True)"| IMGCONTAINER
    VIEW -->|"list_blobs(prefix) + generate_blob_sas(read=True)"| IMGCONTAINER
    DELETE -->|"list_blobs(prefix) + delete_blob() per blob"| IMGCONTAINER

    %% ─── Direct upload from browser ───
    USER -->|"3. Direct PUT to Blob (SAS URL, 1-hour expiry)"| IMGCONTAINER

    %% ─── Storage relationships ───
    SA --> IMGCONTAINER
    SA --> FUNCSTORAGE
    FA -->|"runtime storage"| FUNCSTORAGE

    %% ─── Identity ───
    MI -->|"auto-created with"| FA
    MI -->|"assigned via"| RBAC
    RBAC -->|"grants S3-equivalent CRUD on"| SA
    FUNCKEY -->|"API authentication for SPA"| FA

    %% ─── Monitoring ───
    FA -->|"telemetry (APPLICATIONINSIGHTS_CONNECTION_STRING)"| AI
    AI -->|"ingests logs into"| LAW

    %% ─── IaC provisions all ───
    BICEP -.->|"provisions"| FA
    BICEP -.->|"provisions"| SA
    BICEP -.->|"provisions"| SWA
    BICEP -.->|"provisions"| AI
    BICEP -.->|"provisions"| LAW
    BICEP -.->|"provisions"| RBAC

    %% ─── CI/CD ───
    OIDC -->|"authenticates"| GHA_INFRA
    OIDC -->|"authenticates"| GHA_FUNC
    GHA_SWA -->|"uses SWA deployment token"| SWA
    GHA_INFRA -.->|"deploys via Bicep"| BICEP
    GHA_FUNC -.->|"deploys zip to"| FA
    GHA_SWA -.->|"deploys static files to"| SWA

    %% ─── Pipeline order ───
    GHA_INFRA -->|"1. must complete first"| GHA_FUNC
    GHA_FUNC -->|"2. then deploy functions"| GHA_SWA
