graph TB
    %% ─────────────────────────────────────────────
    %%  Azure Architecture – Image Upload Service
    %%  Migrated from AWS ap-southeast-2
    %%  Target region: australiaeast (Sydney)
    %% ─────────────────────────────────────────────

    subgraph INTERNET["🌐 Public Internet"]
        CLIENT["Browser / API Client"]
    end

    subgraph RG["Azure Resource Group — img-upload-rg  (australiaeast)"]

        subgraph FRONTDOOR_LAYER["── Presentation Layer ──"]
            SWA["Azure Static Web Apps\nimg-upload-swa\n✓ Built-in CDN (Azure CDN)\n✓ Free SSL / Custom Domain\n✓ GitHub Actions CI/CD\nHosts: app.html"]
        end

        subgraph COMPUTE_LAYER["── Compute Layer ──"]
            FUNCAPP["Azure Function App\nimg-upload-func\nRuntime: Python 3.11\nPlan: Consumption (Serverless)\n✓ System-Assigned Managed Identity\n✓ App Insights integrated\n✓ HTTPS only"]

            FN_UPLOAD["upload_function\nHTTP Trigger POST\nGenerates Blob SAS URL (write)\nBlobSasPermissions(write=True)"]
            FN_LIST["list_files_function\nHTTP Trigger GET\nLists blobs in container\ncontainer_client.list_blobs()"]
            FN_VIEW["get_view_url_function\nHTTP Trigger GET\nGenerates Blob SAS URL (read)\nBlobSasPermissions(read=True)"]
            FN_DELETE["delete_file_function\nHTTP Trigger DELETE\nDeletes blob from container\nblob_client.delete_blob()"]
        end

        subgraph IDENTITY_LAYER["── Identity & Access ──"]
            MI["System-Assigned\nManaged Identity\n(on Function App)\nEliminates long-lived secrets"]
            RBAC["Azure RBAC\nStorage Blob Data Contributor\non images container only"]
            ENTRAID["Entra ID\nApp Registration\n(API consumer / frontend)\nClient credential flow\nReplaces IAM user + access key"]
        end

        subgraph STORAGE_LAYER["── Storage Layer ──"]
            SA["Azure Storage Account\nimguploadstore\nKind: StorageV2\nReplication: LRS (dev) / ZRS (prod)\nTLS 1.2 minimum\nPublic blob access: Disabled"]
            CONTAINER["Blob Container\nimages\n✓ Versioning enabled\n✓ Soft delete (7 days)\n✓ CORS configured\n✓ Private — no public access"]
            LIFECYCLE["Lifecycle Policy\nHot → Cool after 90 days\nCool → Archive after 365 days"]
        end

        subgraph OBSERVABILITY_LAYER["── Observability ──"]
            LAW["Log Analytics Workspace\nimg-upload-law\nRetention: 30 days"]
            APPINS["Application Insights\nimg-upload-appins\n✓ Distributed tracing\n✓ Live Metrics\n✓ Failure/Dependency tracking\n✓ Custom dashboards"]
            ALERTS["Azure Monitor Alerts\n• Function error rate > 1%\n• Function 5xx > 5/min\n• Storage latency > 2s"]
        end

        subgraph SECURITY_LAYER["── Security ──"]
            KV["Azure Key Vault\nimg-upload-kv\nStores: Storage conn strings,\nAPIM subscription keys\nAccess: Managed Identity only"]
        end

        subgraph IAC_LAYER["── Infrastructure as Code ──"]
            BICEP["Bicep Templates\nmain.bicep\n├── storage.bicep\n├── functions.bicep\n├── staticweb.bicep\n├── keyvault.bicep\n└── monitoring.bicep"]
        end
    end

    %% ─── Client → Presentation ───
    CLIENT -->|"HTTPS — Load website"| SWA
    CLIENT -->|"HTTPS — API calls\n(x-functions-key header)\nDirect HTTP Trigger"| FUNCAPP

    %% ─── Entra ID auth ───
    ENTRAID -->|"issues token for"| CLIENT

    %% ─── Functions belong to Function App ───
    FUNCAPP -->|"HTTP POST /api/upload_function"| FN_UPLOAD
    FUNCAPP -->|"HTTP GET /api/list_files_function"| FN_LIST
    FUNCAPP -->|"HTTP GET /api/get_view_url_function"| FN_VIEW
    FUNCAPP -->|"HTTP DELETE /api/delete_file_function"| FN_DELETE

    %% ─── Functions → Storage (via Managed Identity) ───
    FN_UPLOAD -->|"generate SAS URL (write)\nvia azure-storage-blob SDK"| CONTAINER
    FN_LIST   -->|"list_blobs()"| CONTAINER
    FN_VIEW   -->|"generate SAS URL (read)"| CONTAINER
    FN_DELETE -->|"delete_blob()"| CONTAINER

    %% ─── Managed Identity → RBAC → Storage ───
    FUNCAPP -->|"authenticates via"| MI
    MI -->|"assigned"| RBAC
    RBAC -->|"grants access to"| CONTAINER
    CONTAINER -->|"belongs to"| SA

    %% ─── Lifecycle ───
    SA -->|"applies"| LIFECYCLE

    %% ─── Key Vault ───
    FUNCAPP -->|"reads secrets from\n(Managed Identity)"| KV

    %% ─── Observability ───
    FUNCAPP -->|"telemetry"| APPINS
    APPINS  -->|"stores in"| LAW
    LAW     -->|"triggers"| ALERTS

    %% ─── IaC ───
    BICEP -.->|"deploys"| SA
    BICEP -.->|"deploys"| FUNCAPP
    BICEP -.->|"deploys"| SWA
    BICEP -.->|"deploys"| KV
    BICEP -.->|"deploys"| LAW
    BICEP -.->|"deploys"| APPINS

    %% ─── Styling ───
    classDef azure_compute    fill:#0078D4,color:#fff,stroke:#005BA1,stroke-width:2px
    classDef azure_storage    fill:#00B388,color:#fff,stroke:#007A5E,stroke-width:2px
    classDef azure_identity   fill:#8B5CF6,color:#fff,stroke:#6D28D9,stroke-width:2px
    classDef azure_observe    fill:#F59E0B,color:#000,stroke:#D97706,stroke-width:2px
    classDef azure_security   fill:#EF4444,color:#fff,stroke:#B91C1C,stroke-width:2px
    classDef azure_static     fill:#0EA5E9,color:#fff,stroke:#0284C7,stroke-width:2px
    classDef azure_iac        fill:#6B7280,color:#fff,stroke:#4B5563,stroke-width:2px
    classDef route_node       fill:#F9FAFB,color:#111,stroke:#D1D5DB,stroke-width:1px

    class FN_UPLOAD,FN_LIST,FN_VIEW,FN_DELETE,FUNCAPP azure_compute
    class SA,CONTAINER,LIFECYCLE azure_storage
    class MI,RBAC,ENTRAID azure_identity
    class LAW,APPINS,ALERTS azure_observe
    class KV azure_security
    class SWA azure_static
    class BICEP azure_iac
    class R1,R2,R3,R4 route_node
