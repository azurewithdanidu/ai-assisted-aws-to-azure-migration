graph TB
    subgraph "Client / Browser"
        CLIENT[Web Browser / API Client]
    end

    subgraph "ap-southeast-2 — Static Hosting"
        WEBSITE["WebsiteBucket\n(S3 Static Website)\nimage-upload-websitebucket-vd866vxtcs1z\napp.html — public read"]
    end

    subgraph "ap-southeast-2 — API Layer"
        APIGW["API Gateway REST API\nimage-upload-api\nhttps://4lrh2l7i86.execute-api.ap-southeast-2.amazonaws.com/dev\nAuth: AWS_IAM / SigV4\nTracing: X-Ray\nLogging: INFO"]
    end

    subgraph "ap-southeast-2 — Compute (Lambda — Python 3.11 / 256 MB)"
        L_UPLOAD["UploadFunction\nupload_handler.lambda_handler\nGenerates pre-signed PUT URL"]
        L_LIST["ListFilesFunction\nlist_handler.lambda_handler\nLists objects in S3"]
        L_VIEW["GetViewUrlFunction\nview_handler.lambda_handler\nGenerates pre-signed GET URL"]
        L_DELETE["DeleteFileFunction\ndelete_handler.lambda_handler\nDeletes object from S3"]
    end

    subgraph "ap-southeast-2 — Storage"
        S3_IMG["ImageBucket (S3)\nimage-upload-imagebucket-t8isnbr8sswv\nVersioning: Enabled\nPublic Access: Blocked\nCORS: Enabled"]
    end

    subgraph "Global — IAM"
        IAM_ROLE["LambdaExecutionRole\nimage-upload-LambdaExecutionRole-2MhYmRQ3aAnA\nAWSLambdaBasicExecutionRole + S3 inline policy"]
        IAM_USER["ApiUser (IAM User)\nimage-upload-api-user\nPermission: execute-api:Invoke on all routes"]
        IAM_APIGW["ApiGatewayCloudWatchLogsRole\nAmazonAPIGatewayPushToCloudWatchLogs"]
    end

    subgraph "ap-southeast-2 — Observability"
        CW_LOGS["CloudWatch Logs\n4x Lambda log groups\n2x API Gateway execution logs"]
        XRAY["X-Ray Tracing\n(API Gateway stage)"]
    end

    subgraph "ap-southeast-2 — IaC"
        CFN["CloudFormation Stack\nimage-upload\nCREATE_COMPLETE"]
    end

    %% Client interactions
    CLIENT -->|"Load website"| WEBSITE
    CLIENT -->|"SigV4 signed requests\n(using IAM User credentials)"| APIGW

    %% IAM User auth
    IAM_USER -->|"allows execute-api:Invoke"| APIGW

    %% API Gateway → Lambda
    APIGW -->|"POST /upload"| L_UPLOAD
    APIGW -->|"GET /files"| L_LIST
    APIGW -->|"GET /files/{fileId}/view-url"| L_VIEW
    APIGW -->|"DELETE /files/{fileId}"| L_DELETE

    %% Lambda → S3
    L_UPLOAD -->|"s3:PutObject / pre-signed URL"| S3_IMG
    L_LIST   -->|"s3:ListBucket"| S3_IMG
    L_VIEW   -->|"s3:GetObject / pre-signed URL"| S3_IMG
    L_DELETE -->|"s3:DeleteObject"| S3_IMG

    %% IAM Role → Lambda
    IAM_ROLE -->|"assumed by"| L_UPLOAD
    IAM_ROLE -->|"assumed by"| L_LIST
    IAM_ROLE -->|"assumed by"| L_VIEW
    IAM_ROLE -->|"assumed by"| L_DELETE

    %% API GW logging role
    IAM_APIGW -->|"used by"| APIGW

    %% Observability
    L_UPLOAD -->|"logs"| CW_LOGS
    L_LIST   -->|"logs"| CW_LOGS
    L_VIEW   -->|"logs"| CW_LOGS
    L_DELETE -->|"logs"| CW_LOGS
    APIGW    -->|"execution logs"| CW_LOGS
    APIGW    -->|"traces"| XRAY

    %% IaC
    CFN -.->|"manages"| APIGW
    CFN -.->|"manages"| L_UPLOAD
    CFN -.->|"manages"| L_LIST
    CFN -.->|"manages"| L_VIEW
    CFN -.->|"manages"| L_DELETE
    CFN -.->|"manages"| S3_IMG
    CFN -.->|"manages"| WEBSITE
    CFN -.->|"manages"| IAM_ROLE
    CFN -.->|"manages"| IAM_USER

    %% Styling
    classDef aws_compute fill:#FF9900,color:#000,stroke:#DD6B00
    classDef aws_storage fill:#3F8624,color:#fff,stroke:#2D6B17
    classDef aws_apigw fill:#E7157B,color:#fff,stroke:#B8006A
    classDef aws_iam fill:#DD344C,color:#fff,stroke:#B02036
    classDef aws_observe fill:#E7157B,color:#fff,stroke:#B8006A
    classDef aws_infra fill:#8C4FFF,color:#fff,stroke:#6A2FCC

    class L_UPLOAD,L_LIST,L_VIEW,L_DELETE aws_compute
    class S3_IMG,WEBSITE aws_storage
    class APIGW aws_apigw
    class IAM_ROLE,IAM_USER,IAM_APIGW aws_iam
    class CW_LOGS,XRAY aws_observe
    class CFN aws_infra
