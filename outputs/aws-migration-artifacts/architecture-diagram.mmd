    %% User flows
    USER -->|"1. Load SPA"| WEB
    WEB -->|"Static files served (app.html)"| USER
    USER -->|"2. API calls (SigV4 signed)"| APIGW

    %% API Gateway → Lambda
    APIGW -->|"POST /upload"| UPLOAD
    APIGW -->|"GET /files"| LIST
    APIGW -->|"GET /files/{fileId}/view-url"| VIEW
    APIGW -->|"DELETE /files/{fileId}"| DELETE

    %% Lambda → S3
    UPLOAD -->|"generate_presigned_post()"| IMG
    LIST -->|"list_objects_v2() + generate_presigned_url()"| IMG
    VIEW -->|"list_objects_v2() + generate_presigned_url()"| IMG
    DELETE -->|"list_objects_v2() + delete_objects()"| IMG

    %% S3 direct upload from browser
    USER -->|"3. Direct S3 PUT (presigned POST URL)"| IMG

    %% IAM relationships
    LAMBDAROLE -->|"assumed by"| UPLOAD
    LAMBDAROLE -->|"assumed by"| LIST
    LAMBDAROLE -->|"assumed by"| VIEW
    LAMBDAROLE -->|"assumed by"| DELETE
    APIGWROLE -->|"assumed by"| APIGW
    APIUSER -->|"signs API requests"| APIGW

    %% Monitoring
    UPLOAD -->|"logs"| LOGS
    LIST -->|"logs"| LOGS
    APIGW -->|"execution logs"| LOGS

    %% CloudFormation manages all
    CFN -.->|"provisions"| UPLOAD
    CFN -.->|"provisions"| LIST
    CFN -.->|"provisions"| VIEW
    CFN -.->|"provisions"| DELETE
    CFN -.->|"provisions"| IMG
    CFN -.->|"provisions"| WEB
    CFN -.->|"provisions"| APIGW
    CFN -.->|"provisions"| LAMBDAROLE
    CFN -.->|"provisions"| APIUSER
