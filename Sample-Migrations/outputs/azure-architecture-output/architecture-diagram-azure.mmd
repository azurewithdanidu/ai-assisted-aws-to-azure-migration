graph TB
    %% ── Azure Target Architecture — Image Upload Service ──
    %% Migrated from AWS ap-southeast-2 → Azure australiaeast (Sydney)

    subgraph Client["Client (Browser)"]
        FE["Web Browser\nSPA — app.html\nFetch API (no SigV4)\nOcp-Apim-Subscription-Key header"]
    end

    subgraph SWA_Layer["Azure Static Web Apps (Free tier)"]
        STATIC["Static Web App\nimg-upload-dev-swa\naustraliaeast\nHTTPS enforced\nRoute: / → /app.html\nReplaces: S3 website bucket"]
    end

    subgraph APIM_Layer["Azure API Management (Consumption tier)"]
        APIM["API Management\nimg-upload-dev-apim\nSubscription Key Auth\nOcp-Apim-Subscription-Key\nCORS: AllowedOrigins=*\nTLS 1.2\nReplaces: API Gateway REST (AWS_IAM/SigV4)"]
        OP_UPLOAD["POST /upload\n→ Function App"]
        OP_LIST["GET /files\n→ Function App"]
        OP_VIEW["GET /files/{fileId}/view-url\n→ Function App"]
        OP_DELETE["DELETE /files/{fileId}\n→ Function App"]
        APIM --> OP_UPLOAD
        APIM --> OP_LIST
        APIM --> OP_VIEW
        APIM --> OP_DELETE
    end

    subgraph FuncApp["Azure Functions v4 (Consumption Plan Y1 · Python 3.11)"]
        FUNC["Function App\nimg-upload-dev-func\nSystem-Assigned Managed Identity\nRuntime: Python|3.11\nAPP SETTINGS:\n  BLOB_CONTAINER_NAME=images\n  URL_EXPIRATION=3600\n  AZURE_STORAGE_ACCOUNT_NAME=...\n  APPLICATIONINSIGHTS_CONNECTION_STRING=...\nReplaces: 4 Lambda functions"]
        FN_UPLOAD["upload_image()\nHTTP POST /upload\nGenerates Blob SAS write URL\nazure-storage-blob\nDefaultAzureCredential\nReplaces: UploadFunction"]
        FN_LIST["list_files()\nHTTP GET /files\nlist_blobs() + SAS read URL per blob\nReplaces: ListFilesFunction"]
        FN_VIEW["get_view_url()\nHTTP GET /files/{fileId}/view-url\nlist_blobs(prefix) + SAS read URL\nReplaces: GetViewUrlFunction"]
        FN_DELETE["delete_file()\nHTTP DELETE /files/{fileId}\ndelete_blob() by prefix\nReplaces: DeleteFileFunction"]
        FUNC --> FN_UPLOAD
        FUNC --> FN_LIST
        FUNC --> FN_VIEW
        FUNC --> FN_DELETE
    end

    subgraph StorageLayer["Azure Blob Storage (Standard LRS)"]
        STORE["Storage Account\nimg-upload-dev-store\nVersioning: ON\nHTTPS only · TLS 1.2\nallowBlobPublicAccess: false\nCORS: ALL methods · AllowedOrigins=*\nReplaces: S3 image bucket (versioned, private)"]
        CONTAINER["Blob Container: images\nAccess: private\nAll access via SAS tokens\nReplaces: s3://image-upload-imagebucket-*"]
        STORE --> CONTAINER
    end

    subgraph KVLayer["Azure Key Vault (Standard)"]
        VAULT["Key Vault\nimg-upload-dev-kv\nSoft-delete: ON\nPurge protection: ON\nRBAC authorization mode\nSecret: apim-subscription-primary-key\nReplaces: IAM user access key in CFN output"]
    end

    subgraph MonitorLayer["Azure Monitor / Observability"]
        AI["Application Insights\nimg-upload-dev-ai\naustraliaeast\nReplaces: CloudWatch + X-Ray"]
        LAW["Log Analytics Workspace\nimg-upload-dev-law\n30-day retention (dev)\nReplaces: CloudWatch Log Groups"]
        AI -->|"linked workspace"| LAW
    end

    subgraph RBAC_Layer["Identity & Access (Azure RBAC)"]
        MI["System-Assigned Managed Identity\nPrincipal: img-upload-dev-func\nRole: Storage Blob Data Contributor\nScope: images container\nReplaces: IAM role + inline S3Access policy"]
    end

    subgraph IaC_Layer["Infrastructure as Code"]
        BICEP["Azure Bicep\nmain.bicep + 7 modules\nReplaces: CloudFormation image-upload stack\nDeploy: az deployment group create\n  --template-file main.bicep\n  --parameters dev.bicepparam"]
    end

    %% ─── Data Flows ──────────────────────────────────────────────────────────

    %% Browser → Static Web App (load SPA)
    FE -->|"HTTPS GET /app.html"| STATIC

    %% Browser → APIM (API calls)
    FE -->|"HTTPS API calls\n+ Ocp-Apim-Subscription-Key"| APIM

    %% APIM → Functions
    OP_UPLOAD  -->|"HTTP forward"| FN_UPLOAD
    OP_LIST    -->|"HTTP forward"| FN_LIST
    OP_VIEW    -->|"HTTP forward"| FN_VIEW
    OP_DELETE  -->|"HTTP forward"| FN_DELETE

    %% Functions → Blob Storage (Managed Identity path)
    FN_UPLOAD  -->|"generate_blob_sas(write)\nBLOB_CONTAINER_NAME"| CONTAINER
    FN_LIST    -->|"list_blobs()\ngenerate_blob_sas(read)"| CONTAINER
    FN_VIEW    -->|"list_blobs(prefix)\ngenerate_blob_sas(read)"| CONTAINER
    FN_DELETE  -->|"delete_blob()"| CONTAINER

    %% Browser → Blob SAS URL (direct upload/download — bypasses APIM)
    FE -->|"PUT to Blob SAS URL\n(direct, no API key needed)\nReplaces: S3 pre-signed POST"| CONTAINER

    %% Managed Identity chain
    FUNC -->|"assumes identity"| MI
    MI   -->|"RBAC assignment\nStorage Blob Data Contributor"| CONTAINER

    %% Key Vault
    APIM -->|"named value reference"| VAULT
    FUNC -->|"Key Vault Secrets User RBAC"| VAULT

    %% Monitoring
    FUNC -->|"APPLICATIONINSIGHTS_CONNECTION_STRING\nautomatc telemetry"| AI
    APIM -->|"diagnostic logs"| AI

    %% IaC manages all
    BICEP -.->|"deploys"| STORE
    BICEP -.->|"deploys"| STATIC
    BICEP -.->|"deploys"| FUNC
    BICEP -.->|"deploys"| APIM
    BICEP -.->|"deploys"| VAULT
    BICEP -.->|"deploys"| AI
    BICEP -.->|"deploys"| LAW
